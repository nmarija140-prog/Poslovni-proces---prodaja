unit Unit2;

interface

uses
  System.SysUtils, System.Types, System.UITypes, System.Classes, System.Variants,
  FMX.Types, FMX.Controls, FMX.Forms, FMX.Graphics, FMX.Dialogs,
  Unit1, FMX.Edit, FMX.Objects, FMX.StdCtrls, FMX.Controls.Presentation,
  FireDAC.Stan.Intf, FireDAC.Stan.Option, FireDAC.Stan.Error, FireDAC.UI.Intf,
  FireDAC.Phys.Intf, FireDAC.Stan.Def, FireDAC.Stan.Pool, FireDAC.Stan.Async,
  FireDAC.Phys, FireDAC.FMXUI.Wait, FireDAC.Stan.Param, FireDAC.DatS,
  FireDAC.DApt.Intf, FireDAC.DApt, Data.DB, FireDAC.Comp.DataSet,
  FireDAC.Comp.Client, FireDAC.Phys.MySQL, FireDAC.Phys.MySQLDef, Data.Win.ADODB;

type
  TForm2 = class(TForm)
    SpeedButton1: TSpeedButton;
    Text1: TText;
    txtbKorisnickoime: TEdit;
    txtbSifra: TEdit;
    PrijavaBtn: TButton;
    Image1: TImage;
    ADOConnection1: TADOConnection;
    ADOQuery1: TADOQuery;
    ADOQuery1korisnickoime: TWideStringField;
    ADOQuery1sifra: TWideStringField;
    DataSource1: TDataSource;
    procedure PrijavaBtnClick(Sender: TObject);
    procedure SpeedButton1Click(Sender: TObject);
  private
    { Private declarations }
  public
    { Public declarations }
  end;

var
  Form2: TForm2;

implementation

{$R *.fmx}

uses Unit3, Unit4;

procedure TForm2.PrijavaBtnClick(Sender: TObject);
var user: string;
var password: string;
begin

user := ADOQuery1.FieldByName('korisnickoime').AsString;
password := ADOQuery1.FieldByName('sifra').AsString;

               ADOQuery1.Close;
               ADOQuery1.SQL.Text :=
  'SELECT korisnickoime FROM login ' +
  'WHERE Trim(korisnickoime) = :u AND Trim(sifra) = :p';

               ADOQuery1.Parameters.ParamByName('u').Value := txtbKorisnickoime.Text;
               ADOQuery1.Parameters.ParamByName('p').Value := txtbSifra.Text;

               ADOQuery1.Open;

               if not ADOQuery1.Eof then
begin
  if SameText(txtbKorisnickoime.Text, 'menadzerprvi') then
    Form3.Show
  else if SameText(txtbKorisnickoime.Text, 'administratorprvi') then
    Form4.Show
  else
    ShowMessage('Nepoznat korisnik');

  Hide;
end
else
  ShowMessage('Pogrešno korisničko ime ili šifra!');



         Close;
end;

procedure TForm2.SpeedButton1Click(Sender: TObject);
begin
            Form1.Show;
            Close;
end;

end.
