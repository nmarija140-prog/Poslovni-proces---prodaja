unit Menadzer;

interface

uses
  System.SysUtils, System.Types, System.UITypes, System.Classes, System.Variants,
  FMX.Types, FMX.Controls, FMX.Forms, FMX.Graphics, FMX.Dialogs,
  FMX.Controls.Presentation, FMX.StdCtrls, FMX.Objects, FMX.Maps, UnosPodataka,
  FMX.ListBox, System.Rtti, FMX.Grid.Style, FMX.ScrollBox, FMX.Grid, Data.DB,
  Data.Win.ADODB;

type
  TForm3 = class(TForm)
    MapView1: TMapView;
    PrijavaBtn: TButton;
    DugmeFakture: TButton;
    Button2: TButton;
    Button3: TButton;
    btnChat: TButton;
    Text1: TText;
    SpeedButton1: TSpeedButton;
    ComboKorisnici: TComboBox;
    ADOQuery1: TADOQuery;
    ADOConnection1: TADOConnection;
    DugmeUdji: TButton;
    procedure SpeedButton1Click(Sender: TObject);
    procedure FormCreate(Sender: TObject);
    procedure DugmeUdjiClick(Sender: TObject);
     procedure DugmeFaktureClick(Sender: TObject);
  private
    AktivniUserID: Integer;
    procedure UcitajKorisnike;

    procedure PrikaziProfilKorisnika;
  public

    { Public declarations }
  end;

var
  Form3: TForm3;

implementation
uses Vozac;

{$R *.fmx}
procedure TForm3.UcitajKorisnike;
var
  userID: Integer;
begin
  if not ADOConnection1.Connected then
    ADOConnection1.Connected := True;

  if ADOQuery1.Active then
    ADOQuery1.Close;


  ADOQuery1.SQL.Text := 'SELECT id, korisnickoime FROM login';
  ADOQuery1.Open;


  ComboKorisnici.Clear;


  while not ADOQuery1.eof do
  begin
    // Hvatanje id
    userID := ADOQuery1.FieldByName('id').AsInteger;

    // Dodavanje u combo
    ComboKorisnici.Items.AddObject(
      ADOQuery1.FieldByName('korisnickoime').AsString,
      TObject(userID)
    );

    ADOQuery1.Next;
  end;
end;

procedure TForm3.DugmeFaktureClick(Sender: TObject);
begin
 if ComboKorisnici.ItemIndex = -1 then
  begin
    ShowMessage('Prvo izaberite korisnika!');
    Exit;
  end;

  AktivniUserID := Integer(ComboKorisnici.Items.Objects[ComboKorisnici.ItemIndex]);
  PrikaziProfilKorisnika;


end;

procedure TForm3.DugmeUdjiClick(Sender: TObject);
begin
  if ComboKorisnici.ItemIndex = -1 then Exit;


  AktivniUserID := Integer(ComboKorisnici.Items.Objects[ComboKorisnici.ItemIndex]);


  ShowMessage('U饝i ste u profil korisnika: ' +
              ComboKorisnici.Text);


  PrikaziProfilKorisnika;

  end;

procedure TForm3.FormCreate(Sender: TObject);
begin
ADOConnection1.ConnectionString :=
    'Provider=Microsoft.Jet.OLEDB.4.0;' +
    'Data Source=' + ExtractFilePath(ParamStr(0)) + 'mpmtransport.mdb;';
  ADOConnection1.LoginPrompt := False;
  ADOConnection1.Connected := True;
UcitajKorisnike;
end;
procedure TForm3.PrikaziProfilKorisnika;
begin
   if AktivniUserID = 0 then Exit;
  ADOQuery1.Close;
  ADOQuery1.SQL.Text := 'SELECT * FROM Fakture WHERE userID = :uid';
  ADOQuery1.Parameters.ParamByName('uid').Value := AktivniUserID;
  ADOQuery1.Open;

  if ADOQuery1.IsEmpty then
    ShowMessage('Nema faktura za izabranog korisnika.');
end;

procedure TForm3.SpeedButton1Click(Sender: TObject);
begin
Form2.Show;
Close;
end;

end.
